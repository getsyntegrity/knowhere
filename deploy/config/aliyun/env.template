# 阿里云环境变量模板
# 复制此文件为 .env.${ENVIRONMENT} 并填入实际值

# 环境配置
ENVIRONMENT=dev  # dev/test/prod
REGION=cn-hangzhou

# 项目配置
PROJECT_NAME=knowhere
DOMAIN_NAME=knowhereto.com

# 容器镜像服务配置
REGISTRY=registry.cn-hangzhou.aliyuncs.com
NAMESPACE=knowhere

# API Webhook配置
# dev环境: https://apidev.knowhereto.com/v1/internal/oss-events
# test环境: https://apitest.knowhereto.com/v1/internal/oss-events
# prod环境: https://api.knowhereto.com/v1/internal/oss-events
API_WEBHOOK_ENDPOINT=https://apidev.knowhereto.com/v1/internal/oss-events

# Kubernetes部署域名配置
# dev环境: API_DOMAIN=apidev.knowhereto.com, WEB_DOMAIN=dev.knowhereto.com, API_URL=https://apidev.knowhereto.com
# test环境: API_DOMAIN=apitest.knowhereto.com, WEB_DOMAIN=test.knowhereto.com, API_URL=https://apitest.knowhereto.com
# prod环境: API_DOMAIN=api.knowhereto.com, WEB_DOMAIN=knowhereto.com, API_URL=https://api.knowhereto.com
API_DOMAIN=apidev.knowhereto.com
WEB_DOMAIN=dev.knowhereto.com
API_URL=https://apidev.knowhereto.com

# 数据库配置
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis配置
REDIS_HOST=your-redis-host
REDIS_PASSWORD=your-redis-password

# RabbitMQ配置（云消息队列RabbitMQ版Serverless）
RABBITMQ_HOST=your-rabbitmq-endpoint
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your-rabbitmq-password
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# OSS配置
OSS_BUCKET_NAME=knowhere-dev-storage-xxxxxxxx
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_SECRET_ACCESS_KEY=your-secret-access-key
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# NAS配置
NAS_MOUNT_TARGET_DOMAIN=your-nas-mount-target.aliyuncs.com

# 应用密钥
SECRET_KEY=your-secret-key

# Stripe配置
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# 前端URL配置（用于Stripe Checkout回调，与WEB_DOMAIN对应）
# dev环境: https://dev.knowhereto.com
# test环境: https://test.knowhereto.com
# prod环境: https://knowhereto.com
FRONTEND_URL=https://dev.knowhereto.com

# OAuth配置（可选，如果配置了则启用对应的OAuth登录）
# Google OAuth：如果配置了GOOGLE_CLIENT_ID和GOOGLE_CLIENT_SECRET，则启用Google登录
# 阿里云环境通常不配置Google OAuth，如需启用只需配置这两个变量即可
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# APPLE_CLIENT_ID=your-apple-client-id
# APPLE_CLIENT_SECRET=your-apple-client-secret

# PostHog配置
POSTHOG_KEY=your-posthog-key

# 版本管理
APP_VERSION=v1.0.0  # 从Git Tag自动获取，或手动设置
GIT_COMMIT=abc1234   # Git commit hash
BUILD_TIME=2024-01-01T00:00:00Z  # 构建时间（UTC）

