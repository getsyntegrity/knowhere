# AWS环境变量模板
# 复制此文件为 .env.${ENVIRONMENT} 并填入实际值

# 环境配置
ENVIRONMENT=dev  # dev/test/prod
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# 项目配置
PROJECT_NAME=knowhere
DOMAIN_NAME=knowhere.ai

# API Webhook配置
API_WEBHOOK_ENDPOINT=https://dev-api.knowhere.ai/v1/internal/s3-events

# 数据库配置
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis配置
REDIS_HOST=your-redis-host
REDIS_PASSWORD=your-redis-password

# RabbitMQ配置（Amazon MQ）
RABBITMQ_HOST=your-amazon-mq-endpoint
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your-rabbitmq-password
RABBITMQ_PORT=5671
RABBITMQ_VHOST=/

# S3配置
S3_BUCKET_NAME=knowhere-dev-storage-xxxxxxxx
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# SNS配置
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:account-id:knowhere-dev-s3-events

# 应用密钥
SECRET_KEY=your-secret-key

# Stripe配置
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# PostHog配置
POSTHOG_KEY=your-posthog-key

# 版本管理
APP_VERSION=v1.0.0  # 从Git Tag自动获取，或手动设置
GIT_COMMIT=abc1234   # Git commit hash
BUILD_TIME=2024-01-01T00:00:00Z  # 构建时间（UTC）

