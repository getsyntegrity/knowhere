# AWS环境变量模板
# 复制此文件为 .env.${ENVIRONMENT} 并填入实际值

# 环境配置
ENVIRONMENT=dev  # dev/test/prod
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# 项目配置
PROJECT_NAME=knowhere
DOMAIN_NAME=knowhere.ai

# API Webhook配置
# dev环境: https://apidev.knowhereto.ai/v1/internal/s3-events
# test环境: https://apitest.knowhereto.ai/v1/internal/s3-events
# prod环境: https://api.knowhereto.ai/v1/internal/s3-events
API_WEBHOOK_ENDPOINT=https://apidev.knowhereto.ai/v1/internal/s3-events

# 数据库配置
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis配置
REDIS_HOST=your-redis-host
REDIS_PASSWORD=your-redis-password

# RabbitMQ配置（Amazon MQ）
RABBITMQ_HOST=your-amazon-mq-endpoint
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your-rabbitmq-password
RABBITMQ_PORT=5671
RABBITMQ_VHOST=/

# S3配置
S3_BUCKET_NAME=knowhere-dev-storage-xxxxxxxx
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# SNS配置
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:account-id:knowhere-dev-s3-events

# 应用密钥
SECRET_KEY=your-secret-key

# Stripe配置
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# PostHog配置
POSTHOG_KEY=your-posthog-key

# OAuth配置（可选，如果配置了则启用对应的OAuth登录）
# Google OAuth：如果配置了GOOGLE_CLIENT_ID和GOOGLE_CLIENT_SECRET，则启用Google登录
# 注意：每个环境（dev/test/prod）需要使用不同的Google OAuth应用
# 在Google Cloud Console中为每个环境创建独立的OAuth 2.0客户端ID
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth：如果配置了GITHUB_CLIENT_ID和GITHUB_CLIENT_SECRET，则启用GitHub登录
# 注意：每个环境（dev/test/prod）需要使用不同的GitHub OAuth应用
# 在GitHub Developer Settings中为每个环境创建独立的OAuth App
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Apple OAuth：如果配置了APPLE_CLIENT_ID和APPLE_CLIENT_SECRET，则启用Apple登录
# 注意：每个环境（dev/test/prod）需要使用不同的Apple OAuth应用
# 在Apple Developer Portal中为每个环境创建独立的Service ID
# APPLE_CLIENT_ID=your-apple-client-id
# APPLE_CLIENT_SECRET=your-apple-client-secret

# 版本管理
APP_VERSION=v1.0.0  # 从Git Tag自动获取，或手动设置
GIT_COMMIT=abc1234   # Git commit hash
BUILD_TIME=2024-01-01T00:00:00Z  # 构建时间（UTC）

