# 阡陌AI知识库管理系统 - 本地开发环境配置
# 基于 Docker Compose 的本地测试环境
# 复制此文件为 .env 并填入实际配置值

# 系统级配置（基础设施）
DATABASE_URL=postgresql+asyncpg://root:root123@localhost:5432/Knowhere

# 数据库SSL配置
DB_SSL_MODE=disable
# DB_SSL_MODE选项: disable, allow, prefer, require, verify-ca, verify-full
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem
# DB_SSL_ROOT_CERT=/path/to/ca-cert.pem

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# RabbitMQ配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# Celery配置
MESSAGE_BROKER_TYPE=rabbitmq
CELERY_BROKER_URL=amqp://admin:admin123@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LocalStack 存储配置（本地开发）
S3_TYPE=oss
# S3_BUCKET_NAME=knowhere-dev
# S3_ACCESS_KEY_ID=test
# S3_SECRET_ACCESS_KEY=test
# S3_ENDPOINT_URL=http://localhost:4566
# S3_PRIVATE_DOMAIN=http://localhost:4566
S3_BUCKET_NAME=knowhere-api-dev
# S3_ACCESS_KEY_ID=your-s3-access-key-id
# S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
# S3_ENDPOINT_URL=https://s3.us-west-1.amazonaws.com
# S3_PRIVATE_DOMAIN=https://s3.us-west-1.amazonaws.com
S3_TEMP_PATH=/tmp

# OSS
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
OSS_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com

# 阿里云 SLB 配置（用于 Kubernetes LoadBalancer Service）
# 如果配置了 SLB 实例 ID，Service 将使用 LoadBalancer 类型并关联到指定的 SLB
# 如果未配置，Service 将使用 ClusterIP 类型
API_SLB_ID=your-api-slb-id
WEB_SLB_ID=lb-7xvvb0zg6v1ndbqo1g24v

# 应用级配置
APP_TITLE=KnowHere AI知识库管理系统
APP_VERSION=1.0.0
APP_DESCRIPTION=基于AI的知识库管理和智能问答系统
TMP_PATH=/tmp/knowhere
FONT_PATH=/usr/share/fonts
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# 安全配置
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 开放API管理配置
USERS_VERIFY_TOKEN_SECRET=dev-verify-token-secret
USERS_RESET_PASSWORD_TOKEN_SECRET=dev-reset-token-secret

# Stripe 支付配置（测试环境）
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OAuth 配置（开发环境）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=your-email@gmail.com
EMAILS_FROM_NAME=AI Smart Bid

# AI模型配置
DS_KEY=your-deepseek-api-key
DS_URL=https://api.deepseek.com/v1/chat/completions
ALI_API_KEY=your-ali-api-key-1,your-ali-api-key-2
ALI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ARK_API_KEY=your-ark-api-key-1,your-ark-api-key-2
ARK_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
GPT_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-v4
NORMOL_MODEL=deepseek-chat
IMAGE_MODEL=qwen-vl-plus
IMAGE_MODEL_MAX=qwen-vl-max

# 文件处理配置
SUPPORTED_EXTENSIONS=.doc,.docx,.pdf,.txt,.xls,.xlsx,.csv,.jpg,.png
MAX_FILE_SIZE=104857600
MAX_IMAGE_SIZE=10485760

# 模型参数配置
MIN_CONFIDENCE_THRESHOLD=0.05
HIGH_IOU_THRESHOLD=0.9
DEFAULT_EMBEDDING_DIM=1024
DEFAULT_TOP_K=5
DEFAULT_BATCH_SIZE=32
DEFAULT_EPOCHS=3
DEFAULT_THRESHOLD=0.5

# MinerU 文档解析配置
MINERU_API_KEY=****
MINERU_URL=https://mineru.net/api/v4

# 开发/生产环境
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# 兼容性字段（保留现有字段，逐步迁移）
ALL_DF_COLS=content,path,type,length,keywords,summary,know_id,tokens,connectto,addtime
DEFAULT_FOLDERS=默认目录,Supplementary_Files,Temporary_Files,templates,images,fragments
KB_TERM=KB_DATA
KB_VEC_TERM=KB_VECS

# 默认配置文件路径
META_PATH=app/core/config/Meta_setting.csv
CONFIG_PATH=app/core/config/config.txt

PATH_IMAGE_PATTERN=.*\.(png|jpe?g|gif)$
IMG_TBL_PATTERN=TABLE_.*?_TABLE|IMAGE_.*?_IMAGE
SPLIT_CHAR=-->

# 用户数据目录路径（API和Worker共享，必须配置绝对路径）
USERS_DATA_PATH=/app/users


# Web前端服务配置
# API URL（构建时配置，需要 NEXT_PUBLIC_ 前缀）
API_URL=https://apitest.knowhereto.com
NEXT_PUBLIC_API_URL=${API_URL}
# 公司信息配置（运行时动态配置，不带 NEXT_PUBLIC_ 前缀）
# 这些配置通过服务端组件在 SSR 时直接读取环境变量，支持运行时修改
# 实现方式：服务端组件读取环境变量，通过 React Context 传递给客户端组件
COMPANY_NAME=深圳市渊维科技有限公司
SIMPLE_COMPANY_NAME=渊维科技
# ICP备案信息（国内部署时使用，海外部署可留空）
ICP_NUMBER=
ICP_URL=https://beian.miit.gov.cn/