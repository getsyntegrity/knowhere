# Terraform Backend 配置示例 - 阿里云
# 复制此文件为 backend.tf 并填入实际值
# 
# 注意：backend 配置不能使用变量，必须硬编码或使用环境变量
# 建议使用环境变量或 terraform init -backend-config 来配置

terraform {
  backend "oss" {
    # OSS bucket 用于存储 state 文件
    # 格式：{project_name}-terraform-state-{environment}
    bucket = "knowhere-terraform-state-dev"  # 需要先手动创建此 bucket
    
    # State 文件在 OSS 中的路径
    # 每个环境使用不同的 prefix
    prefix = "terraform.tfstate"
    
    # 阿里云区域
    region = "cn-guangzhou"
    
    # 启用加密
    encrypt = true
    
    # 可选：使用 RAM 角色（推荐用于生产环境）
    # role_arn = "acs:ram::account-id:role/terraform-role"
  }
}

