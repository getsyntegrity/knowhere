# Terraform变量示例文件 - 阿里云部署
# 
# ⚠️  重要说明：Terraform 仅用于 prod 环境（main 分支）的 Serverless 部署
# - dev 环境：不进行远程部署，仅本地开发（不使用 Terraform）
# - test 环境：使用 ECS + Docker Compose（不使用 Terraform）
# - prod 环境：使用 ACK (Kubernetes) Serverless（使用 Terraform）✅
# 
# 使用方法：
#   cp terraform.tfvars.example terraform.tfvars.prod
#   编辑 terraform.tfvars.prod，填入生产环境的实际值
#
#   terraform apply -var-file=terraform.tfvars.prod

# ============================================================================
# 必需变量（必须设置，无默认值）
# ============================================================================

# 阿里云凭证配置
access_key = "your-aliyun-access-key-id"
secret_key = "your-aliyun-secret-access-key"

# 主账号凭证（用于处理需要更高权限的资源，如 ACK 集群）
# 如果未提供，将使用上面的 RAM 用户凭证
# 注意：主账号凭证具有完整权限，请妥善保管
master_access_key = ""  # 主账号 AccessKey ID（可选）
master_secret_key = ""  # 主账号 AccessKey Secret（可选）

# 域名配置
domain_name = "knowhereto.com"

# 数据库配置
db_password = "YourSecurePassword123!"

# RabbitMQ配置
rabbitmq_password = "YourRabbitMQPassword123!"

# ============================================================================
# 基础配置（有默认值，但建议明确设置）
# ============================================================================

# 阿里云配置
region = "cn-guangzhou"  # 阿里云区域（华南3-广州）

# 环境配置
environment = "prod"  # 环境名称: 必须设置为 "prod"（Terraform 仅用于 prod 环境）
# 注意：project_name 和 rabbitmq_username 使用默认值（在 variables.tf 中定义）
# 如需覆盖，可以在此设置：
# project_name = "knowhere"
# rabbitmq_username = "admin"

# 应用版本配置（建议通过命令行自动获取，不要在此文件中设置）
# 版本号会自动从Git获取：
#   - 如果有Tag（prod环境）：使用Tag（如 v1.0.0）
#   - 如果没有Tag：使用环境名+commit hash（如 prod-abc1234）
# 
# 使用方法：
#   terraform apply -var-file=terraform.tfvars.prod \
#     -var="app_version=$(git describe --tags --exact-match HEAD 2>/dev/null || echo 'prod-$(git rev-parse --short HEAD)')"
#
# 或者使用部署脚本（推荐），脚本会自动获取版本号

# API Webhook端点（用于OSS事件通知）
# prod环境的webhook端点：
#   - prod环境: https://api.{domain_name}/v1/internal/oss-events
# 如果不设置，OSS事件通知将无法工作
api_webhook_endpoint = "https://api.knowhereto.com/v1/internal/oss-events"

# ============================================================================
# OSS存储配置（敏感信息）
# ============================================================================

# OSS存储配置
# 注意：OSS桶名会根据环境自动生成，格式为：{project_name}-{environment}-storage-{8位随机字符串}
# prod环境示例：knowhere-prod-storage-xxxxxxxx
# 部署后可通过以下命令查看桶名：
#   terraform output oss_bucket_name
oss_access_key_id     = ""  # OSS访问密钥ID（RAM用户AccessKey）
oss_secret_access_key = ""  # OSS秘密访问密钥（RAM用户SecretKey）

# ============================================================================
# 其他环境变量配置（可选，根据实际需求填写）
# ============================================================================
# 参考 apps/api/env.example 查看所有可用的环境变量
# 以下列出部分常用的可选配置：

# Redis配置
# redis_password = ""  # Redis密码（如果为空则不需要密码）
# redis_database = 0   # Redis数据库编号

# 存储配置
# s3_type = "oss"  # 存储类型: s3, oss, minio
# s3_region = "cn-guangzhou"  # S3/OSS区域
# s3_use_ssl = true  # 是否使用SSL
# s3_addressing_style = "auto"  # S3寻址风格
# oss_endpoint = ""  # OSS endpoint（如果为空则自动生成）
# s3_private_domain = ""  # S3私有域名

# 第三方服务配置
# resend_api_key = ""  # Resend邮件API密钥
# moesif_application_id = ""  # Moesif应用ID
# stripe_webhook_secret = ""  # Stripe Webhook密钥

# OAuth配置
# google_client_id = ""
# google_client_secret = ""
# github_client_id = ""
# github_client_secret = ""
# apple_client_id = ""
# apple_client_secret = ""

# 邮件配置
# smtp_host = "smtp.gmail.com"
# smtp_port = 587
# smtp_user = ""
# smtp_password = ""
# emails_from_email = ""
# emails_from_name = "AI Smart Bid"

# AI模型配置
# ds_key = ""  # DeepSeek API密钥
# ali_api_key = ""  # 阿里云API密钥
# ark_api_key = ""  # 火山引擎API密钥
# gpt_api_key = ""  # OpenAI API密钥
# mineru_api_key = ""  # MinerU API密钥

# 安全配置
# users_verify_token_secret = ""  # 用户验证令牌密钥
# users_reset_password_token_secret = ""  # 用户重置密码令牌密钥
# webhook_signing_secret = ""  # Webhook签名密钥
# s3_webhook_auth_token = ""  # S3/MinIO Webhook认证令牌
# oss_event_callback_key = ""  # OSS事件回调密钥

# ============================================================================
# 应用安全配置（敏感信息）
# ============================================================================

# 应用安全配置
app_secret_key = ""  # 应用JWT密钥（用于签名token，必须设置，建议使用强随机字符串）

# Stripe支付配置（可选，如果不需要支付功能可以留空）
stripe_secret_key      = ""  # Stripe密钥（格式: sk_live_... 或 sk_test_...）
stripe_publishable_key = ""  # Stripe发布密钥（格式: pk_live_... 或 pk_test_...）

# PostHog分析配置（可选，如果不需要分析功能可以留空）
posthog_key = ""  # PostHog密钥（格式: phc_xxx）

# ============================================================================
# 注意事项
# ============================================================================
# 1. 所有包含敏感信息的变量都会存储到Kubernetes Secrets中
# 2. 如果变量值为空字符串，secret会被创建但值为空，需要后续手动设置
# 3. 生产环境建议使用强密码和密钥
# 4. 不同环境应使用不同的密码和密钥
# 5. 此文件已添加到 .gitignore，不会提交到版本控制
# 6. 阿里云使用Kubernetes Secrets存储敏感信息，而不是Secrets Manager

