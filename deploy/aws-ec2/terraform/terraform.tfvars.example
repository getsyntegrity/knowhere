# Terraform变量配置文件示例
# 复制此文件为 terraform.tfvars 并填入实际值

# AWS配置
aws_region = "us-east-1"

# 项目配置
project_name = "knowhere"
environment  = "test"
domain_name  = "knowhereto.ai"

# 子域名配置
api_subdomain = "apitest"
web_subdomain = "test"

# 实例配置
instance_type        = "t3.large"
root_volume_size     = 50
root_volume_type     = "gp3"
root_volume_iops     = 3000

# 网络配置（使用现有资源）
use_existing_vpc              = false
existing_vpc_id               = ""
use_existing_security_group   = false
existing_security_group_id    = ""

# 数据库配置（使用现有资源）
use_existing_rds              = false
existing_rds_identifier       = ""
use_existing_redis            = false
existing_redis_identifier     = ""

# S3配置（使用现有资源）
use_existing_s3               = false
existing_s3_bucket_name       = ""

# 密钥配置
create_key_pair = true
key_pair_name   = ""

# 监控配置
enable_detailed_monitoring     = false
cloudwatch_log_retention_days = 7
notification_email            = ""

# SSL配置
enable_ssl            = true
ssl_certificate_arn   = ""

# 标签
common_tags = {
  Project     = "knowhere"
  Environment = "test"
  ManagedBy   = "terraform"
  Owner       = "your-team"
}
