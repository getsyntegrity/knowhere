# Knowhere环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ===================
# 基础配置
# ===================
ENVIRONMENT=test
DEBUG=false
LOG_LEVEL=INFO

# ===================
# 数据库配置
# ===================
# PostgreSQL数据库连接
DATABASE_URL=postgresql://postgres:your-password@your-rds-endpoint:5432/knowhere

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ===================
# Redis配置
# ===================
REDIS_HOST=your-redis-endpoint
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# ===================
# S3存储配置
# ===================
S3_BUCKET_NAME=knowhere-test-storage
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=us-east-1
S3_ENDPOINT_URL=

# ===================
# API配置
# ===================
SECRET_KEY=your-secret-key-here-change-this-in-production
API_HOST=0.0.0.0
API_PORT=5005
API_WORKERS=2

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "https://test.knowhereto.ai"]
CORS_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_HEADERS=["*"]

# ===================
# Web前端配置
# ===================
NEXT_PUBLIC_API_URL=https://apitest.knowhereto.ai
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ===================
# Celery Worker配置
# ===================
CELERY_BROKER_URL=redis://your-redis-endpoint:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-endpoint:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# ===================
# RabbitMQ配置（如果使用）
# ===================
RABBITMQ_HOST=your-rabbitmq-host
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ===================
# 邮件配置
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
SMTP_SSL=false

# ===================
# 第三方服务配置
# ===================
# Stripe支付
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# PostHog分析
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_HOST=https://app.posthog.com

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ===================
# 安全配置
# ===================
# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码加密
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_HASH_ROUNDS=12

# ===================
# 监控配置
# ===================
# CloudWatch
CLOUDWATCH_GROUP_NAME=/aws/ec2/knowhere-test
CLOUDWATCH_STREAM_NAME=app-logs
CLOUDWATCH_REGION=us-east-1

# 健康检查
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5

# ===================
# 缓存配置
# ===================
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://your-redis-endpoint:6379/1
CACHE_DEFAULT_TIMEOUT=300

# ===================
# 文件上传配置
# ===================
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=["image/jpeg", "image/png", "image/gif", "application/pdf"]
UPLOAD_PATH=/opt/knowhere/uploads

# ===================
# 日志配置
# ===================
LOG_FILE_PATH=/opt/knowhere/logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ===================
# 开发配置
# ===================
# 热重载（仅开发环境）
RELOAD=false
# 调试模式
DEBUG_TOOLBAR=false
# 测试数据库
TEST_DATABASE_URL=postgresql://postgres:test@localhost:5432/knowhere_test
