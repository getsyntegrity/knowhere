# 前端 Dockerfile - 多阶段构建（支持 monorepo）
FROM node:18-alpine AS base

# 安装依赖阶段
FROM base AS deps
WORKDIR /app

# 复制 monorepo 配置文件
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY turbo.json ./

# 复制所有 workspace 包的 package.json（用于依赖解析）
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/sdk-typescript/package.json ./packages/sdk-typescript/
COPY packages/openapi-specs/package.json ./packages/openapi-specs/
COPY apps/web/package.json ./apps/web/
COPY apps/docs/package.json ./apps/docs/

# 安装所有依赖（包括 workspace 依赖）
RUN corepack enable pnpm && \
    pnpm install --frozen-lockfile

# 构建阶段
FROM base AS builder
WORKDIR /app

# 构建参数 - Next.js NEXT_PUBLIC_API_URL（必须在构建时传入，会被内联到客户端代码中）
# 默认值使用 next.config.js 中的默认值，确保向后兼容
ARG NEXT_PUBLIC_API_URL=https://apitest.knowhereto.ai
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# 注意：公司名称、ICP等配置不再在构建时设置
# 这些配置通过运行时环境变量设置（COMPANY_NAME, SIMPLE_COMPANY_NAME, ICP_NUMBER, ICP_URL）
# 服务端组件在 SSR 时读取这些环境变量，通过 React Context 传递给客户端组件

# 复制 monorepo 配置文件
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY turbo.json ./

# 复制所有 workspace 包的 package.json（用于依赖解析）
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/sdk-typescript/package.json ./packages/sdk-typescript/
COPY packages/openapi-specs/package.json ./packages/openapi-specs/
COPY apps/web/package.json ./apps/web/
COPY apps/docs/package.json ./apps/docs/

# 从 deps 阶段复制已安装的依赖（避免重新下载）
COPY --from=deps /app/node_modules ./node_modules

# 复制所有源代码
COPY packages ./packages
COPY apps/web ./apps/web
COPY apps/docs ./apps/docs

# 重新运行 pnpm install 来建立正确的 workspace 链接（使用 --prefer-offline 避免重新下载）
RUN corepack enable pnpm && \
    pnpm install --frozen-lockfile --prefer-offline

# 构建应用（使用 pnpm filter 只构建 web 应用及其依赖）
RUN pnpm --filter @knowhere/web build

# 生产阶段
FROM base AS runner
WORKDIR /app

# 构建参数 - 版本信息
ARG ENVIRONMENT=dev
ARG APP_VERSION=dev
ARG BUILD_TIME=""
ARG GIT_COMMIT=""

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV ENVIRONMENT=${ENVIRONMENT}
ENV APP_VERSION=${APP_VERSION}
ENV BUILD_TIME=${BUILD_TIME}
ENV GIT_COMMIT=${GIT_COMMIT}

# 创建非root用户
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# 复制构建产物（从 apps/web 目录）
# 注意：public 目录的内容已经包含在 .next/standalone 中，无需单独复制
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./apps/web/.next/standalone
# 复制静态文件到 standalone 目录内的正确位置（Next.js standalone 模式需要）
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/standalone/apps/web/.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

WORKDIR /app/apps/web/.next/standalone
CMD ["node", "apps/web/server.js"]

