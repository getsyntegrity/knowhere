version: '3.8'

services:
  # PostgreSQL 数据库
  postgres:
    image: postgres:15-alpine
    container_name: knowhere-test-postgres
    ports:
      - "5433:5432"  # 使用5433避免冲突
    environment:
      POSTGRES_DB: Knowhere
      POSTGRES_USER: root
      POSTGRES_PASSWORD: root123
      POSTGRES_INITDB_ARGS: "--encoding=UTF-8 --lc-collate=C --lc-ctype=C"
    volumes:
      - postgres_test_data:/var/lib/postgresql/data
      - ../local-dev/postgres/init:/docker-entrypoint-initdb.d
    networks:
      - knowhere_test_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U root -d Knowhere"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  # Redis 缓存
  redis:
    image: redis:7-alpine
    container_name: knowhere-test-redis
    ports:
      - "6380:6379"  # 使用6380避免冲突
    command: redis-server --appendonly yes --maxmemory 2gb --maxmemory-policy allkeys-lru
    volumes:
      - redis_test_data:/data
    networks:
      - knowhere_test_network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # RabbitMQ 消息队列
  rabbitmq:
    image: rabbitmq:3.12-management
    container_name: knowhere-test-rabbitmq
    ports:
      - "5673:5672"    # AMQP端口（使用5673避免冲突）
      - "15673:15672"  # 管理界面端口（使用15673避免冲突）
    environment:
      RABBITMQ_DEFAULT_USER: admin
      RABBITMQ_DEFAULT_PASS: admin123
      RABBITMQ_DEFAULT_VHOST: /
    volumes:
      - rabbitmq_test_data:/var/lib/rabbitmq
    networks:
      - knowhere_test_network
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  # MinIO 对象存储（用于S3兼容测试）
  minio:
    image: minio/minio:latest
    container_name: knowhere-test-minio
    ports:
      - "9002:9000"    # API端口（使用9002避免冲突）
      - "9003:9001"    # 控制台端口（使用9003避免冲突）
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin123
    command: server /data --console-address ":9001"
    volumes:
      - minio_test_data:/data
      - ../local-dev/minio/init:/etc/minio/init
    networks:
      - knowhere_test_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  # LocalStack AWS服务模拟
  localstack:
    image: localstack/localstack:3.8
    container_name: knowhere-test-localstack
    ports:
      - "4567:4566"    # LocalStack Edge端口（使用4567避免冲突）
    environment:
      SERVICES: s3,sns,sqs,lambda,iam,sts
      DEBUG: 1
      PERSISTENCE: 1
      DATA_DIR: /var/lib/localstack/data
      S3_SKIP_SIGNATURE_VALIDATION: 1
      S3_SKIP_SSL_VERIFICATION: 1
      HOSTNAME_EXTERNAL: localstack
      EDGE_PORT: 4566
      SNS_ENDPOINT_STRATEGY: domain
      DOCKER_HOST: unix:///var/run/docker.sock
    volumes:
      - localstack_test_data:/var/lib/localstack
      - /var/run/docker.sock:/var/run/docker.sock
      - ../local-dev/localstack/init:/etc/localstack/init/ready.d
    networks:
      - knowhere_test_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4566/_localstack/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s


  # API服务
  api:
    build:
      context: ../..
      dockerfile: deploy/docker/Dockerfile.api
    image: knowhere-api:test
    container_name: knowhere-test-api
    ports:
      - "5005:5005"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
      minio:
        condition: service_healthy
      localstack:
        condition: service_healthy
