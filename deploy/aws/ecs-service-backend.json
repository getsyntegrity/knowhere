{
  "serviceName": "knowhere-backend-service",
  "cluster": "knowhere-cluster",
  "taskDefinition": "knowhere-backend",
  "desiredCount": 2,
  "launchType": "FARGATE",
  "platformVersion": "LATEST",
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "subnets": [
        "subnet-xxxxxxxxx",
        "subnet-yyyyyyyyy"
      ],
      "securityGroups": [
        "sg-xxxxxxxxx"
      ],
      "assignPublicIp": "ENABLED"
    }
  },
  "loadBalancers": [
    {
      "targetGroupArn": "arn:aws:elasticloadbalancing:YOUR_REGION:YOUR_ACCOUNT_ID:targetgroup/knowhere-backend-tg/xxxxxxxxx",
      "containerName": "knowhere-backend",
      "containerPort": 5005
    }
  ],
  "serviceRegistries": [
    {
      "registryArn": "arn:aws:servicediscovery:YOUR_REGION:YOUR_ACCOUNT_ID:service/srv-xxxxxxxxx"
    }
  ],
  "deploymentConfiguration": {
    "maximumPercent": 200,
    "minimumHealthyPercent": 50,
    "deploymentCircuitBreaker": {
      "enable": true,
      "rollback": true
    }
  },
  "healthCheckGracePeriodSeconds": 300,
  "enableExecuteCommand": true,
  "tags": [
    {
      "key": "Environment",
      "value": "production"
    },
    {
      "key": "Application",
      "value": "knowhere"
    },
    {
      "key": "Component",
      "value": "backend"
    }
  ]
}
