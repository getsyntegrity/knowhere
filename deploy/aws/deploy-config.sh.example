#!/bin/bash
# 部署配置文件模板
# 复制此文件为 deploy-config.sh 并填写实际配置值
# 注意: deploy-config.sh 不会被提交到 git，包含敏感信息

# EC2 服务器配置
export EC2_HOST="your-ec2-ip"
export EC2_USER="ec2-user"  # 或 ubuntu，取决于 AMI
export SSH_KEY="scripts/id_rsa"  # 可选，留空则不使用。支持相对路径（相对于 deploy/aws）、绝对路径或 ~ 开头的路径

# GitHub Container Registry 配置
export GITHUB_USERNAME="your-github-username"
export GITHUB_TOKEN="your-github-personal-access-token"  # 可选，用于 GHCR 登录

# SSL 证书配置
export SSL_DOMAINS="apitest.knowhereto.ai test.knowhereto.ai"
export SSL_EMAIL="admin@knowhereto.ai"

