# Terraform Backend 配置文件 - 开发环境
# 
# ⚠️  重要说明：dev 环境不使用 Terraform
# - dev 环境：不进行远程部署，仅本地开发
# - 请使用本地开发环境配置：deploy/local-dev/README.md
# 
# 此文件仅作为参考保留，实际部署不使用 Terraform
# 
# 如果确实需要使用（不推荐），使用方法：
#   terraform init -backend-config=backend-config.dev

bucket         = "knowhere-terraform-state-dev"
key            = "terraform.tfstate"
region         = "us-west-1"  # 根据实际环境设置
dynamodb_table = "knowhere-terraform-locks-dev"
encrypt        = true

