# Terraform Backend 配置示例
# 复制此文件为 backend.tf 并填入实际值
# 
# 注意：backend 配置不能使用变量，必须硬编码或使用环境变量
# 建议使用环境变量或 terraform init -backend-config 来配置

terraform {
  backend "s3" {
    # S3 bucket 用于存储 state 文件
    # 格式：{project_name}-terraform-state-{environment}
    bucket = "knowhere-terraform-state-dev"  # 需要先手动创建此 bucket
    
    # State 文件在 S3 中的路径
    # 每个环境使用不同的 key
    key = "terraform.tfstate"
    
    # AWS 区域
    region = "us-east-1"
    
    # DynamoDB 表用于 state 锁定（防止并发修改）
    # 格式：{project_name}-terraform-locks-{environment}
    dynamodb_table = "knowhere-terraform-locks-dev"  # 需要先手动创建此表
    
    # 启用加密
    encrypt = true
    
    # 可选：使用 KMS 密钥加密（如果设置了）
    # kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"
  }
}

