# users_data_path = "/opt/knowhere/users"

# ============================================================================
# 注意事项
# ============================================================================
# 1. 所有包含敏感信息的变量都会存储到AWS Secrets Manager
# 2. 如果变量值为空字符串，secret会被创建但值为空，需要后续手动设置：
#    aws secretsmanager update-secret --secret-id "knowhere/{environment}/secret-name" --secret-string "value"
# 3. 生产环境建议使用强密码和密钥
# 4. 不同环境应使用不同的密码和密钥
# 5. 此文件已添加到 .gitignore，不会提交到版本控制
