# Terraform变量示例文件
# 
# ⚠️  重要说明：Terraform 仅用于 prod 环境（main 分支）的 Serverless 部署
# - dev 环境：不进行远程部署，仅本地开发（不使用 Terraform）
# - test 环境：使用 EC2 + Docker Compose（不使用 Terraform）
# - prod 环境：使用 ECS Fargate Serverless（使用 Terraform）✅
# 
# 使用方法：
#   cp terraform.tfvars.example terraform.tfvars.prod
#   编辑 terraform.tfvars.prod，填入生产环境的实际值
#
#   terraform apply -var-file=terraform.tfvars.prod

# ============================================================================
# 必需变量（必须设置，无默认值）
# ============================================================================

# 域名配置
domain_name = "knowhereto.ai"

# 数据库配置
db_password = "YourSecurePassword123!"

# RabbitMQ配置
mq_password = "YourRabbitMQPassword123!"

# ============================================================================
# 基础配置（有默认值，但建议明确设置）
# ============================================================================

# AWS配置
aws_region = "us-east-1"  # AWS区域

# 环境配置
environment = "prod"  # 环境名称: 必须设置为 "prod"（Terraform 仅用于 prod 环境）
# 注意：project_name 和 mq_username 使用默认值（在 variables.tf 中定义）
# 如需覆盖，可以在此设置：
# project_name = "knowhere"
# mq_username = "admin"

# 应用版本配置（建议通过命令行自动获取，不要在此文件中设置）
# 版本号会自动从Git获取：
#   - 如果有Tag（prod环境）：使用Tag（如 v1.0.0）
#   - 如果没有Tag：使用环境名+commit hash（如 prod-abc1234）
# 
# 使用方法：
#   terraform apply -var-file=terraform.tfvars.prod \
#     -var="app_version=$(git describe --tags --exact-match HEAD 2>/dev/null || echo 'prod-$(git rev-parse --short HEAD)')"
#
# 或者使用部署脚本（推荐），脚本会自动获取版本号

# API Webhook端点（用于S3事件通知）
# prod环境的webhook端点：
#   - prod环境: https://api.{domain_name}/v1/internal/s3-events
# 如果不设置，S3事件通知将无法工作
api_webhook_endpoint = "https://api.knowhereto.ai/v1/internal/s3-events"

# ============================================================================
# Secrets Manager 配置（敏感信息）
# 这些变量会存储到AWS Secrets Manager中，供应用使用
# 如果留空，secret会被创建但值为空，需要后续手动设置
# ============================================================================

# S3存储配置
# 注意：S3桶名会根据环境自动生成，格式为：{project_name}-{environment}-storage-{8位随机字符串}
# prod环境示例：knowhere-prod-storage-xxxxxxxx
# 部署后可通过以下命令查看桶名：
#   terraform output s3_bucket_name
s3_access_key_id     = ""  # S3访问密钥ID（IAM用户Access Key）
s3_secret_access_key = ""  # S3秘密访问密钥（IAM用户Secret Key）

# 应用安全配置
app_secret_key = ""  # 应用JWT密钥（用于签名token，必须设置，建议使用强随机字符串）

# Stripe支付配置（可选，如果不需要支付功能可以留空）
stripe_secret_key      = ""  # Stripe密钥（格式: sk_live_... 或 sk_test_...）
stripe_publishable_key = ""  # Stripe发布密钥（格式: pk_live_... 或 pk_test_...）
stripe_webhook_secret  = ""  # Stripe Webhook密钥（格式: whsec_...）

# PostHog分析配置（可选，如果不需要分析功能可以留空）
posthog_key = ""  # PostHog密钥（格式: phc_xxx）

# ============================================================================
# 其他环境变量配置（可选，根据实际需求填写）
# ============================================================================
# 参考 apps/api/env.example 查看所有可用的环境变量
# 以下列出部分常用的可选配置：

# 用户验证密钥
# users_verify_token_secret = ""  # 用户验证令牌密钥
# users_reset_password_token_secret = ""  # 用户重置密码令牌密钥

# Webhook配置
# webhook_signing_secret = ""  # Webhook签名密钥
# s3_webhook_auth_token = ""  # S3/MinIO Webhook认证令牌

# 第三方服务配置
# resend_api_key = ""  # Resend邮件API密钥
# moesif_application_id = ""  # Moesif应用ID

# OAuth配置
