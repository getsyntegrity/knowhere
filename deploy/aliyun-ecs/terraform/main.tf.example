# 阿里云 ECS 部署 Terraform 配置示例
# 这是从 AWS EC2 迁移到阿里云 ECS 的 Terraform 配置

terraform {
  required_version = ">= 1.0"
  required_providers {
    alicloud = {
      source  = "aliyun/alicloud"
      version = "~> 1.200"
    }
  }
}

provider "alicloud" {
  # 从环境变量读取认证信息
  # export ALICLOUD_ACCESS_KEY=xxx
  # export ALICLOUD_SECRET_KEY=xxx
  region = var.region
}

# 数据源 - 获取可用区信息
data "alicloud_zones" "available" {
  available_resource_creation = "VSwitch"
}

# 数据源 - 获取可用的镜像
# 查找Ubuntu 22.04镜像
data "alicloud_images" "ubuntu_2204" {
  name_regex = "ubuntu_22_04_64"
  owners     = "system"
  most_recent = true
}

# VPC专有网络
resource "alicloud_vpc" "main" {
  vpc_name   = "${var.project_name}-${var.environment}-vpc"
  cidr_block = "10.0.0.0/16"
  description = "VPC for Knowhere deployment"
  
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-vpc"
  })
}

# 交换机（对应AWS的Subnet）
resource "alicloud_vswitch" "public" {
  count = 2 # 配置2个交换机提高可用性
  
  vpc_id     = alicloud_vpc.main.id
  cidr_block = "10.0.${count.index + 1}.0/24"
  zone_id    = data.alicloud_zones.available.zones[count.index].id
  vswitch_name = "${var.project_name}-${var.environment}-public-vswitch-${count.index + 1}"
  
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-public-vswitch-${count.index + 1}"
  })
}

resource "alicloud_vswitch" "private" {
  count = 2
  
  vpc_id     = alicloud_vpc.main.id
  cidr_block = "10.0.${count.index + 10}.0/24"
  zone_id    = data.alicloud_zones.available.zones[count.index].id
  vswitch_name = "${var.project_name}-${var.environment}-private-vswitch-${count.index + 1}"
  
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-private-vswitch-${count.index + 1}"
  })
}

# 安全组（对应AWS的Security Group）
resource "alicloud_security_group" "app_server" {
  name        = "${var.project_name}-${var.environment}-app-server-sg"
  vpc_id      = alicloud_vpc.main.id
  description = "Security group for Knowhere app servers"
  
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-app-server-sg"
  })
}

# 安全组规则 - HTTP
resource "alicloud_security_group_rule" "http_ingress" {
  type              = "ingress"
  ip_protocol       = "tcp"
  nic_type          = "internet"
  policy            = "accept"
  port_range        = "80/80"
  priority          = 1
  security_group_id = alicloud_security_group.app_server.id
  cidr_ip           = "0.0.0.0/0"
  description       = "Allow HTTP access"
}

# 安全组规则 - HTTPS
resource "alicloud_security_group_rule" "https_ingress" {
  type              = "ingress"
  ip_protocol       = "tcp"
  nic_type          = "internet"
  policy            = "accept"
  port_range        = "443/443"
  priority          = 1
  security_group_id = alicloud_security_group.app_server.id
  cidr_ip           = "0.0.0.0/0"
  description       = "Allow HTTPS access"
}

# 安全组规则 - SSH
resource "alicloud_security_group_rule" "ssh_ingress" {
  type              = "ingress"
  ip_protocol       = "tcp"
  nic_type          = "internet"
  policy            = "accept"
  port_range        = "22/22"
  priority          = 1
  security_group_id = alicloud_security_group.app_server.id
  cidr_ip           = "0.0.0.0/0" # 生产环境应限制到特定IP
  description       = "Allow SSH access"
}

# 安全组规则 - Backend API
resource "alicloud_security_group_rule" "api_ingress" {
  type              = "ingress"
  ip_protocol       = "tcp"
  nic_type          = "intranet"
  policy            = "accept"
  port_range        = "5005/5005"
  priority          = 1
  security_group_id = alicloud_security_group.app_server.id
  cidr_ip           = "0.0.0.0/0"
  description       = "Allow Backend API access"
}

# 安全组规则 - Web Frontend
resource "alicloud_security_group_rule" "web_ingress" {
  type              = "ingress"
  ip_protocol       = "tcp"
  nic_type          = "intranet"
  policy            = "accept"
  port_range        = "3000/3000"
  priority          = 1
  security_group_id = alicloud_security_group.app_server.id
  cidr_ip           = "0.0.0.0/0"
  description       = "Allow Web Frontend access"
}

# 密钥对
resource "alicloud_ecs_key_pair" "app_key" {
  key_pair_name = "${var.project_name}-${var.environment}-key"
  public_key    = file("${path.module}/../scripts/id_rsa.pub")
  
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-key"
  })
}

# ECS实例（对应AWS的EC2）
resource "alicloud_instance" "app_server" {
  instance_name  = "${var.project_name}-${var.environment}-app-server"
  instance_type  = var.instance_type
  image_id       = data.alicloud_images.ubuntu_2204.images[0].id
  security_groups = [alicloud_security_group.app_server.id]
  
  # 使用第一个公共子网
  vswitch_id = alicloud_vswitch.public[0].id
  
  # SSH密钥对
  key_name = alicloud_ecs_key_pair.app_key.key_pair_name
  
  # 系统盘配置
  system_disk_category = "cloud_essd"
  system_disk_size     = var.root_volume_size
  
  # 公网IP（直接分配）
  internet_max_bandwidth_out = 10
  internet_charge_type       = "PayByTraffic"
  
  # 用户数据（启动脚本）
  user_data = base64encode(templatefile("${path.module}/../user-data/ecs-instance-init.sh", {
    project_name = var.project_name
    environment  = var.environment
    region       = var.region
  }))
  
  # 标签
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-app-server"
  })
}

# RDS PostgreSQL实例（对应AWS的RDS）
resource "alicloud_db_instance" "main" {
  engine           = "PostgreSQL"
  engine_version   = "15.0"
  instance_type    = "pg.n2.medium.1" # 等同于AWS的db.t3.micro
  instance_storage = 20
  instance_name    = "${var.project_name}-${var.environment}-db"
  instance_charge_type = "Postpaid"
  
  # 网络配置
  vpc_id     = alicloud_vpc.main.id
  vswitch_id = alicloud_vswitch.private[0].id
  
  # 安全配置
  security_ips = [alicloud_vswitch.private[0].cidr_block]
  
  # 备份配置
  backup_time = "03:00Z-04:00Z"
  
  # 标签
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-db"
  })
}

# ApsaraDB Redis（对应AWS的ElastiCache）
resource "alicloud_kvstore_instance" "main" {
  instance_name  = "${var.project_name}-${var.environment}-redis"
  instance_class = "redis.master.small.default" # 1核1G
  instance_type  = "Redis"
  engine_version = "7.0"
  vpc_id         = alicloud_vpc.main.id
  vswitch_id     = alicloud_vswitch.private[0].id
  security_ips   = [alicloud_vswitch.private[0].cidr_block]
  
  # 端口配置
  port = 6379
  
  # 标签
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-redis"
  })
}

# OSS存储桶（对应AWS的S3）
resource "alicloud_oss_bucket" "main" {
  bucket = "${var.project_name}-${var.environment}-storage"
  acl    = "private"
  
  # 加密配置
  server_side_encryption_rule {
    sse_algorithm = "AES256"
  }
  
  # 版本控制
  versioning {
    status = "Enabled"
  }
  
  # 标签
  tags = merge(var.common_tags, {
    Name = "${var.project_name}-${var.environment}-storage"
  })
}

# 输出配置
output "ecs_public_ip" {
  value = alicloud_instance.app_server.public_ip
}

output "ecs_private_ip" {
  value = alicloud_instance.app_server.private_ip
}

output "rds_endpoint" {
  value = alicloud_db_instance.main.connection_string
}

output "redis_endpoint" {
  value = alicloud_kvstore_instance.main.connection_domain
}

output "oss_endpoint" {
  value = alicloud_oss_bucket.main.location
}

