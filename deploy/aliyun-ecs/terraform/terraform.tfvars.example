# Terraform变量配置文件示例
# 复制此文件为 terraform.tfvars 并填入实际值

# 阿里云配置
region     = "cn-hangzhou"
# access_key 和 secret_key 可以通过环境变量 ALICLOUD_ACCESS_KEY 和 ALICLOUD_SECRET_KEY 设置
# access_key = "your-access-key"
# secret_key = "your-secret-key"

# 项目配置
project_name = "knowhere"
environment  = "test"
domain_name  = "knowhereto.ai"

# 子域名配置
api_subdomain = "apitest"
web_subdomain = "test"

# 实例配置
instance_type    = "ecs.c7.large"
root_volume_size = 50
root_volume_type = "cloud_essd"

# 网络配置（使用现有资源）
use_existing_vpc            = false
existing_vpc_id             = ""
use_existing_security_group = false
existing_security_group_id  = ""

# 数据库配置（使用现有资源）
use_existing_rds        = false
existing_rds_instance_id = ""
use_existing_redis      = false
existing_redis_instance_id = ""

# OSS配置（使用现有资源）
use_existing_oss      = false
existing_oss_bucket_name = ""

# 密钥配置
create_key_pair = true
key_pair_name   = ""

# 监控配置
enable_cloud_monitor = true
log_retention_days   = 7
notification_email   = ""

# SSL配置
enable_ssl        = true
ssl_certificate_id = ""

# 标签
common_tags = {
  Project     = "knowhere"
  Environment = "test"
  ManagedBy   = "terraform"
  Owner       = "your-team"
}

