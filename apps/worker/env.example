# 阡陌AI知识库管理系统 - 本地开发环境配置
# 基于 Docker Compose 的本地测试环境
# 复制此文件为 .env 并填入实际配置值

# 系统级配置（基础设施）
DATABASE_URL=postgresql+asyncpg://root:root123@localhost:5432/Knowhere
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Celery Redis broker / backend 配置
# Example TLS URL:
# CELERY_REDIS_URL=rediss://:password@redis-host:6379/0?ssl_cert_reqs=CERT_NONE
CELERY_REDIS_URL=redis://localhost:6379/0
BROKER_POOL_LIMIT=10

DB_SSL_MODE=disable
# DB_SSL_MODE选项: disable, allow, prefer, require, verify-ca, verify-full
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem
# DB_SSL_ROOT_CERT=/path/to/ca-cert.pem

# MinIO 存储配置（本地开发）
#S3_BUCKET_NAME=knowhere-uploads
#S3_ACCESS_KEY_ID=minioadmin
#S3_SECRET_ACCESS_KEY=minioadmin123
#S3_ENDPOINT_URL=http://localhost:9000
#S3_PRIVATE_DOMAIN=http://localhost:9000

S3_TEMP_PATH=/tmp
S3_BUCKET_NAME=knowhere-api-dev
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_ENDPOINT_URL=https://s3.us-west-1.amazonaws.com
S3_PRIVATE_DOMAIN=https://s3.us-west-1.amazonaws.com

# S3 高级配置
S3_TYPE=s3
S3_REGION=us-west-1
S3_USE_SSL=true
S3_ADDRESSING_STYLE=auto
S3_UPLOADS_BUCKET=knowhere-uploads
S3_RESULTS_BUCKET=knowhere-results

# Webhook 配置
WEBHOOK_SIGNING_SECRET=your-webhook-secret
S3_WEBHOOK_AUTH_TOKEN=your-s3-webhook-token
SNS_SIGNATURE_VERIFICATION=true

# OSS 配置（可选）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_EVENT_CALLBACK_KEY=your-oss-callback-key
OSS_EVENT_VERIFY_SIGNATURE=true

# Resend 邮件配置
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@knowhere.ai
RESEND_FROM_NAME=Knowhere AI
RESEND_MAX_RETRIES=3
RESEND_RETRY_DELAY=1.0

# Moesif 配置
MOESIF_APPLICATION_ID=your_moesif_app_id

# PostHog 配置
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# 订阅配置
FREE_PLAN_INITIAL_CREDITS=100
# CREDITS_PER_PAGE is deprecated. Use MICRO_DOLLARS_PER_PAGE instead (default: 1500 = $0.0015/page)

# 应用级配置
APP_TITLE=KnowHere AI知识库管理系统
APP_VERSION=1.0.0
APP_DESCRIPTION=基于AI的知识库管理和智能问答系统
TMP_PATH=/tmp/knowhere
FONT_PATH=/usr/share/fonts
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# 安全配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 开放API管理配置
USERS_VERIFY_TOKEN_SECRET=your-verify-token-secret
USERS_RESET_PASSWORD_TOKEN_SECRET=your-reset-token-secret

# Stripe 支付配置（测试环境）
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OAuth 配置（开发环境）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=your-email@gmail.com
EMAILS_FROM_NAME=AI Smart Bid

# Stripe 支付配置
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhook配置
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here
WEBHOOK_MASTER_KEY=your_webhook_master_key_here

# QStash webhook delivery settings
# Webhook delivery is always published via Upstash QStash.
QSTASH_TOKEN=
# Public API base URL used to build callback endpoints.
# The code appends /webhooks/qstash/callback and /webhooks/qstash/failure.
# In this project the public base should include /api/v1.
QSTASH_CALLBACK_BASE_URL=https://api.example.com/api/v1
QSTASH_MAX_RETRIES=5
# API service only: callback signature verification keys from Upstash.
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# 存储事件通知配置
# S3/MinIO事件通知
S3_WEBHOOK_AUTH_TOKEN=your-minio-webhook-token
SNS_SIGNATURE_VERIFICATION=true

# OSS事件通知配置（仅S3_TYPE=oss时需要）
OSS_EVENT_CALLBACK_KEY=your-oss-callback-key
OSS_EVENT_VERIFY_SIGNATURE=true

# Resend邮件配置（Worker服务中邮件服务已移除，此配置保留用于兼容性）
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@knowhere.ai
RESEND_FROM_NAME=AI Smart Bid
RESEND_MAX_RETRIES=3
RESEND_RETRY_DELAY=1.0

# Moesif配置
MOESIF_APPLICATION_ID=your_moesif_app_id

# PostHog配置
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# 订阅配置
FREE_PLAN_INITIAL_CREDITS=5

# S3配置（如需新增）
S3_UPLOADS_BUCKET=knowhere-uploads
S3_RESULTS_BUCKET=knowhere-results

# AI模型配置
GLM_API_KEY=your-glm-api-key
GLM_URL=https://open.bigmodel.cn/api/paas/v4
DS_KEY=your-deepseek-api-key
DS_URL=https://api.deepseek.com/v1/chat/completions
ALI_API_KEYS=your-ali-api-key-1,your-ali-api-key-2
ALI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ARK_API_KEYS=your-ark-api-key-1,your-ark-api-key-2
ARK_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
GPT_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-v4
# GLM (备用): glm-5 文本 + glm-4v 图像理解
# NORMOL_MODEL=glm-5
# IMAGE_MODEL=glm-4v
# IMAGE_MODEL_MAX=glm-4v
# 切换回千问/DeepSeek: 取消下面三行注释，注释上面三行
NORMOL_MODEL=qwen3.5-flash #deepseek-chat
IMAGE_MODEL=qwen3.5-flash
IMAGE_MODEL_MAX=qwen3.5-flash

# 文件处理配置
SUPPORTED_EXTENSIONS=.doc,.docx,.pdf,.txt,.xls,.xlsx,.csv,.jpg,.png
MAX_FILE_SIZE=104857600
MAX_IMAGE_SIZE=10485760

# 模型参数配置
MIN_CONFIDENCE_THRESHOLD=0.05
HIGH_IOU_THRESHOLD=0.9
DEFAULT_EMBEDDING_DIM=1024
DEFAULT_TOP_K=5
DEFAULT_BATCH_SIZE=32
DEFAULT_EPOCHS=3
DEFAULT_THRESHOLD=0.5

# MinerU 文档解析配置
MINERU_API_KEYS=your-mineru-api-key-list
MINERU_URL=https://mineru.net/api/v4

# iLoveAPI 配置 (PPTX 转 PDF)
ILOVEAPI_PUBLIC_KEY=project_public_ba2798a1580fa9c0f1cbe56edbbd1df8_A3UNhe167d03af17c3febeb23eb2681b1298a
ILOVEAPI_SECRET_KEY=your-iloveapi-secret-key
ILOVEAPI_BASE_URL=https://api.ilovepdf.com/v1
ILOVEAPI_TIMEOUT=120

# 开发/生产环境
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# 兼容性字段（保留现有字段，逐步迁移）
ALL_DF_COLS=content,path,type,length,keywords,summary,know_id,tokens,connectto,addtime,page_nums
DEFAULT_FOLDERS=默认目录,Supplementary_Files,Temporary_Files,templates,images,fragments
KB_TERM=KB_DATA
KB_VEC_TERM=KB_VECS

# 默认配置文件路径
META_PATH=app/core/config/Meta_setting.csv
CONFIG_PATH=app/core/config/config.txt

PATH_IMAGE_PATTERN=.*\.(png|jpe?g|gif)$
IMG_TBL_PATTERN=TABLE_.*?_TABLE|IMAGE_.*?_IMAGE
SPLIT_CHAR=/


# 用户数据目录
USERS_DATA_PATH=/path/to/users
